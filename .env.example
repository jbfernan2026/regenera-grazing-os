# =============================================================================
# Regenera Grazing OS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Get this from: https://console.neon.tech → Your project → Connection Details
# Make sure to select "Prisma" as the connection method
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/regenera?sslmode=require"

# Direct connection URL (for migrations — bypasses Neon's connection pooler)
DIRECT_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/regenera?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — for Google sign-in)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Regenera Grazing OS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform super admin email (first user with this email gets super admin role)
PLATFORM_ADMIN_EMAIL="jaime@example.com"

# -----------------------------------------------------------------------------
# Feature Flags (Phase 1)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH="false"
NEXT_PUBLIC_ENABLE_REGISTRATION="true"
