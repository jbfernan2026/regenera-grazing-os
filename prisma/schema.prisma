// =============================================================================
// Regenera Grazing OS — Prisma Schema (Phase 1)
// =============================================================================
// Multi-tenant SaaS: single database + tenant_id strategy
// All tenant-scoped tables include tenantId for Row Level Security
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, uuidOssp(map: "uuid-ossp")]
}

// =============================================================================
// PLATFORM LEVEL — Not tenant-scoped
// =============================================================================

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  displayName String
  description String?
  maxUsers     Int @default(3)
  maxFarms     Int @default(1)
  maxPaddocks  Int @default(20)
  maxStorage   Int @default(1024)
  gisAdvanced         Boolean @default(false)
  longTermMonitoring  Boolean @default(false)
  documentUpload      Boolean @default(false)
  traceabilityLayer   Boolean @default(false)
  exportAdvanced      Boolean @default(false)
  apiAccess           Boolean @default(false)
  whiteLabel          Boolean @default(false)
  priceMonthly  Int @default(0)
  priceYearly   Int @default(0)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants Tenant[]
  @@map("plans")
}

// =============================================================================
// TENANT LEVEL — Organization / Company
// =============================================================================

model Tenant {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  slug        String  @unique
  description String?
  email    String?
  phone    String?
  website  String?
  country  String  @default("CL")
  timezone String  @default("America/Santiago")
  locale   String  @default("es")
  planId         String   @db.Uuid
  plan           Plan     @relation(fields: [planId], references: [id])
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt    DateTime?
  logoUrl   String?
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  memberships TenantMembership[]
  invitations TenantInvitation[]
  auditLogs   AuditLog[]
  wholeUnderManagements WholeUnderManagement[]
  farms       Farm[]
  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

// =============================================================================
// USER & AUTH — NextAuth.js compatible + multi-tenant membership
// =============================================================================

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  name                String?
  passwordHash        String
  platformRole        PlatformRole @default(USER)
  registrationStatus  RegistrationStatus @default(PENDING_APPROVAL)
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  accounts            Account[]
  sessions            Session[]
  tenantMemberships   TenantMembership[]
  decisionMakers      DecisionMaker[]
  @@map("users")
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

enum RegistrationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model TenantMembership {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role     TenantRole @default(FIELD_OPERATOR)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

enum TenantRole {
  OWNER
  FARM_MANAGER
  FIELD_OPERATOR
  ADVISOR
  REVIEWER
}

model TenantInvitation {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  role      TenantRole @default(FIELD_OPERATOR)
  token     String     @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())
  @@index([tenantId])
  @@index([token])
  @@index([email])
  @@map("tenant_invitations")
}

// =============================================================================
// NEXTAUTH.JS REQUIRED TABLES
// =============================================================================

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// PHASE 2A: WHOLE UNDER MANAGEMENT + HOLISTIC CONTEXT
// =============================================================================

model WholeUnderManagement {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  exploitationType ExploitationType @default(PRIMARY_PRODUCTION)
  totalAreaHa  Float?
  annualRainfallMm    Float?
  seasonRainfallMm    Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  holisticContext  HolisticContext?
  decisionMakers   DecisionMaker[]
  farms            Farm[]
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("whole_under_management")
}

enum ExploitationType {
  PRIMARY_PRODUCTION
  VALUE_ADDED
  MIXED
}

model HolisticContext {
  id    String @id @default(uuid()) @db.Uuid
  wumId String @unique @db.Uuid
  wum   WholeUnderManagement @relation(fields: [wumId], references: [id], onDelete: Cascade)
  tenantId String @db.Uuid
  qualityOfLife String? @db.Text
  formsOfProduction String? @db.Text
  futureResourceBase String? @db.Text
  notes String? @db.Text
  lastReviewedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId])
  @@map("holistic_contexts")
}

model DecisionMaker {
  id    String @id @default(uuid()) @db.Uuid
  wumId String @db.Uuid
  wum   WholeUnderManagement @relation(fields: [wumId], references: [id], onDelete: Cascade)
  tenantId String @db.Uuid
  name     String
  role     String?
  email    String?
  phone    String?
  userId   String?  @db.Uuid
  user     User?    @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId])
  @@index([wumId])
  @@map("decision_makers")
}

// =============================================================================
// PHASE 2B: FARMS (PREDIOS)
// =============================================================================

model Farm {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wumId String @db.Uuid
  wum   WholeUnderManagement @relation(fields: [wumId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text
  country    String  @default("CL")
  region     String?
  commune    String?
  address    String?
  latitude   Float?
  longitude  Float?
  totalAreaHa Float?
  usableAreaHa Float?
  climateZone     String?
  avgAnnualTempC  Float?
  annualRainfallMm Float?
  frostFreeDays    Int?
  predominantSoilType String?
  soilDepthCm         Int?
  organicMatterPct    Float?
  waterSource    String?
  irrigationType String?
  hasWaterRights Boolean @default(false)
  elevationM     Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId])
  @@index([wumId])
  @@index([tenantId, isActive])
  @@map("farms")
}

// =============================================================================
// AUDIT LOG — Tenant-scoped activity tracking
// =============================================================================

model AuditLog {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String?  @db.Uuid
  action   String
  entity   String
  entityId String?  @db.Uuid
  metadata Json    @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}